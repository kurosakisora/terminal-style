              "name": "execute_bash",
              "orig_name": "execute_bash",
              "args": {
                "command": "# Let's check what the actual escape sequence ;5;13~ means\n# In xterm modified key format: CSI code ; modifiers ~\n# modifier 5 = Ctrl, code 13 doesn't map to standard keys\n# But wait - let's check if this is actually from Ctrl+E (0x05 = ENQ)\n# In Kitty keyboard protocol, Ctrl+E would be encoded differently\n\n# Let's check if Ghostty has a config to disable the enhanced keyboard protocol\ngrep -c \"keyboard\" /Applications/Ghostty.app/Contents/Resources/man/man5/ghostty.5 2>/dev/null\necho \"---\"\n# Search for the actual config option\npython3 -c \"\nimport re\nwith open('/Applications/Ghostty.app/Contents/Resources/man/man5/ghostty.5') as f:\n    content = f.read()\n# Find all config option names (they appear as bold code blocks)\noptions = re.findall(r'\\\\\\\\f\\[CB\\]([a-z][a-z0-9-]+)\\\\\\\\f', content)\nfor opt in sorted(set(options)):\n    print(opt)\n\" 2>/dev/null | grep -i \"key\\|term\\|compat\"",
                "summary": "Find all Ghostty config options related to keyboard"
              },
              "orig_args": {
                "command": "# Let's check what the actual escape sequence ;5;13~ means\n# In xterm modified key format: CSI code ; modifiers ~\n# modifier 5 = Ctrl, code 13 doesn't map to standard keys\n# But wait - let's check if this is actually from Ctrl+E (0x05 = ENQ)\n# In Kitty keyboard protocol, Ctrl+E would be encoded differently\n\n# Let's check if Ghostty has a config to disable the enhanced keyboard protocol\ngrep -c \"keyboard\" /Applications/Ghostty.app/Contents/Resources/man/man5/ghostty.5 2>/dev/null\necho \"---\"\n# Search for the actual config option\npython3 -c \"\nimport re\nwith open('/Applications/Ghostty.app/Contents/Resources/man/man5/ghostty.5') as f:\n    content = f.read()\n# Find all config option names (they appear as bold code blocks)\noptions = re.findall(r'\\\\\\\\f\\[CB\\]([a-z][a-z0-9-]+)\\\\\\\\f', content)\nfor opt in sorted(set(options)):\n    print(opt)\n\" 2>/dev/null | grep -i \"key\\|term\\|compat\"",
                "summary": "Find all Ghostty config options related to keyboard"
              }
            }
